NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin1@umich.edu,admin2@umich.edu,urvim@umich.edu
NEXT_PUBLIC_ADMIN_EMAILS=admin1@umich.edu,admin2@umich.edu,urvim@umich.edu

# Mux server-side credentials
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-signing-secret

# Site URL used for auth redirects and Mux CORS origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Content moderation (UM-GPT Toolkit) ────────────────────────────
# Server-side ONLY. Do NOT prefix with NEXT_PUBLIC_.
# Get keys from https://api.toolkit.umgpt.umich.edu/
UMGPT_API_KEY=your-umgpt-api-key
UMGPT_BASE_URL=https://api.toolkit.umgpt.umich.edu/v1
# Model used for both text and vision moderation. gpt-4o supports vision.
UMGPT_MODEL=gpt-4o

# Optional: local Whisper model for audio transcription (default whisper-base).
# Larger models are more accurate but slower and use more memory.
# WHISPER_MODEL=Xenova/whisper-base

# Optional: video frame sampling interval in seconds (default 5).
# MODERATION_FRAME_INTERVAL_SEC=5
